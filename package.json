{
  "name": "mouse-gestures",
  "displayName": "Mouse Gestures",
  "description": " An extension to capture mouse gestures and execute commands in Visual Studio Code.",
  "version": "1.1.19",
  "icon": "media/icon.png",
  "publisher": "ngSoftware",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pungggi/mouse_gestures.git"
  },
  "bugs": {
    "url": "https://github.com/pungggi/mouse_gestures/issues"
  },
  "homepage": "https://github.com/pungggi/mouse_gestures#readme",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gesturePadContainer",
          "title": "Gesture Pad",
          "icon": "media/mouse.svg"
        }
      ]
    },
    "views": {
      "gesturePadContainer": [
        {
          "id": "gesturePadView",
          "name": "",
          "type": "webview",
          "icon": "media/mouse.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "mouseGestures.cheatSheet",
        "title": "Show Cheat Sheet",
        "category": "Mouse Gestures"
      },
      {
        "command": "mouseGestures.startQuickPad",
        "title": "Start QuickPad",
        "category": "Mouse Gestures"
      },
      {
        "command": "mouseGestures.cancelQuickPad",
        "title": "Cancel QuickPad",
        "category": "Mouse Gestures"
      }
    ],
    "keybindings": [
      {
        "command": "mouseGestures.startQuickPad",
        "key": "alt+g",
        "mac": "alt+g"
      }
    ],
    "configuration": {
      "title": "Mouse Gestures",
      "properties": {
        "mouseGestures.pathColor": {
          "type": "string",
          "default": "#cccccc",
          "description": "Color of the gesture path"
        },
        "mouseGestures.pathThickness": {
          "type": "number",
          "default": 1,
          "description": "Thickness of the gesture path in pixels"
        },
        "mouseGestures.showGesturePreview": {
          "type": "boolean",
          "default": true,
          "description": "Show gesture preview after completion"
        },
        "mouseGestures.gestureCommands": {
          "type": "array",
          "default": [
            {
              "gesture": "R",
              "actions": [
                {
                  "command": "workbench.action.nextEditor",
                  "description": "Switch to next editor"
                }
              ]
            },
            {
              "gesture": "L",
              "actions": [
                {
                  "command": "workbench.action.previousEditor",
                  "description": "Switch to previous editor"
                }
              ]
            },
            {
              "gesture": "U",
              "button": "left",
              "inputType": "mouse",
              "when": "editorTextFocus",
              "actions": [
                {
                  "command": "editor.action.moveLinesUpAction",
                  "description": "Move line up when in editor"
                }
              ]
            },
            {
              "gesture": "U",
              "when": "explorerViewletVisible && explorerViewletFocus",
              "actions": [
                {
                  "command": "list.collapseAll",
                  "description": "Collapse all in explorer when explorer is focused"
                }
              ]
            },
            {
              "gesture": "D",
              "when": "editorTextFocus",
              "actions": [
                {
                  "command": "editor.action.moveLinesDownAction",
                  "description": "Move line down when in editor"
                }
              ]
            },
            {
              "gesture": "DR",
              "when": "editorLangId == \"typescript\" || editorLangId == \"javascript\"",
              "actions": [
                {
                  "command": "editor.action.goToDeclaration",
                  "description": "Go to declaration in TypeScript/JavaScript files"
                }
              ]
            }
          ],
          "items": {
            "type": "object",
            "required": [
              "gesture",
              "actions"
            ],
            "properties": {
              "gesture": {
                "type": "string",
                "description": "The gesture string. Use 'R' (right), 'L' (left), 'U' (up), 'D' (down), or combinations like 'DR' (down-right), 'LRUD', etc."
              },
              "inputType": {
                "type": "string",
                "enum": [
                  "mouse",
                  "wheel",
                  "any"
                ],
                "default": "any",
                "description": "Specifies the input type this gesture applies to: 'mouse' (drag), 'wheel', or 'any' (both)."
              },
              "executionMode": {
                "type": "string",
                "enum": [
                  "sequential",
                  "parallel"
                ],
                "default": "sequential",
                "description": "Whether to execute commands sequentially or in parallel"
              },
              "button": {
                "type": "string",
                "enum": [
                  "left",
                  "middle",
                  "right"
                ],
                "description": "Specifies the mouse button this gesture applies to: 'left', 'middle', or 'right'. If not set, the gesture matches any mouse button."
              },
              "actions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "anyOf": [
                    {
                      "required": [
                        "command"
                      ]
                    },
                    {
                      "required": [
                        "keystroke"
                      ]
                    }
                  ],
                  "properties": {
                    "command": {
                      "type": "string",
                      "description": "The VS Code command ID to execute"
                    },
                    "keystroke": {
                      "type": "string",
                      "description": "A keystroke to simulate (e.g. 'Enter', 'Tab', or any text). Use this when you want to send a raw key instead of a command."
                    },
                    "description": {
                      "type": "string",
                      "description": "Optional description of what this command does"
                    },
                    "waitSeconds": {
                      "type": "number",
                      "default": 1,
                      "description": "Number of seconds to wait before executing the next command. This is useful for creating delays between commands."
                    },
                    "args": {
                      "type": "array",
                      "description": "Optional arguments to pass to the command",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              },
              "group": {
                "type": "string",
                "description": "Optional group name for organizing gestures in the cheat sheet."
              },
              "when": {
                "type": "string",
                "description": "Optional when clause context expression that determines when this gesture is active. Uses the same syntax as VS Code keyboard shortcuts. Supported keys: editorFocus, editorTextFocus, editorHasSelection, editorHasMultipleSelections, editorReadonly, editorLangId, editorIsDirty, editorLineNumber, isInDiffEditor, resourceScheme, resourceFilename, resourceExtname, resourceDirname, resourcePath, resourceLangId, isFileSystemResource, inDebugMode, debugType, debugState, debuggersAvailable, terminalFocus, terminalIsOpen, terminalCount, isLinux, isMac, isWindows, isWeb, workspaceFolderCount, workbenchState, editorIsOpen, multipleEditorGroups, groupEditorsCount, activeEditorGroupIndex, activeEditorGroupLast, activeEditorGroupEmpty, windowFocused, config.*. Operators: &&, ||, !, ==, !=, >, <, >=, <=, =~, in, not in, and parentheses. Examples: 'editorTextFocus', 'editorLangId == \"typescript\"', 'inDebugMode && editorIsDirty'"
              }
            }
          },
          "description": "Maps mouse gestures to VS Code commands. Each entry maps a gesture to one or more commands to execute."
        },
        "mouseGestures.quickPad.autoClose": {
          "type": "boolean",
          "default": true,
          "description": "Automatically close QuickPad after gesture completion"
        },
        "mouseGestures.quickPad.inactivityTimeoutMs": {
          "type": "number",
          "default": 6000,
          "description": "Auto-close QuickPad after inactivity (milliseconds)"
        },
        "mouseGestures.quickPad.showHint": {
          "type": "boolean",
          "default": true,
          "description": "Show hint text in QuickPad overlay"
        }
      }
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "copy-webpack-plugin": "^14.0.0",
    "globals": "^17.4.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  }
}